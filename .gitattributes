# Normalize all text files to LF in the repository.
# Git will still check out CRLF on Windows if core.autocrlf=true,
# but the repo canonical form is LF — no more "LF will be replaced" warnings.
* text=auto eol=lf

# Explicitly binary — never mangle these.
*.bin   binary
*.gz    binary
*.uf2   binary
*.zip   binary
*.png   binary
*.jpg   binary
*.pdf   binary
